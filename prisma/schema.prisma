generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  RIDER
  DRIVER
}

enum VehicleType {
  CAR
  SHUTTLE
  KEKE
}

enum RideStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  RESET
}

// ============================================
// USER & IDENTITY
// ============================================

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String?   @unique
  name          String?
  firstName     String?
  lastName      String?
  avatar        String?
  roles         Role[]    @default([RIDER])
  homeArea      String?
  homeLat       Float?
  homeLng       Float?
  workArea      String?
  workLat       Float?
  workLng       Float?
  rating        Float     @default(0)
  ratingCount   Int       @default(0)
  isOnboarded   Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Identity verification
  ninVerified         Boolean   @default(false)
  ninNumber           String?
  ninVerifiedAt       DateTime?

  // Relations
  driverProfile       DriverProfile?
  rides               Ride[]          @relation("DriverRides")
  bookings            Booking[]       @relation("RiderBookings")
  ratingsGiven        Rating[]        @relation("RatingsGiven")
  ratingsReceived     Rating[]        @relation("RatingsReceived")
  payments            Payment[]
  sessions            Session[]
  identityChecks      IdentityCheck[]

  @@index([phone])
  @@index([isActive, roles])
}

model DriverProfile {
  id                  String            @id @default(cuid())
  userId              String            @unique
  vehicleType         VehicleType
  vehicleMake         String?
  vehicleModel        String?
  vehicleYear         Int?
  vehicleColor        String?
  plateNumber         String
  maxSeats            Int
  licenseNumber       String?
  licenseVerified     Boolean           @default(false)
  licenseVerifiedAt   DateTime?
  licensePhotoUrl     String?
  vehiclePhotoUrl     String?
  bankAccountNumber   String?
  bankCode            String?
  bankName            String?
  bankAccountName     String?
  bankVerified        Boolean           @default(false)
  faceVerified        Boolean           @default(false)
  faceVerifiedAt      DateTime?
  isApproved          Boolean           @default(false)
  approvedAt          DateTime?
  totalEarnings       Int               @default(0) // in kobo
  availableBalance    Int               @default(0) // in kobo
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals         Withdrawal[]

  @@index([isApproved])
  @@index([userId])
}

// ============================================
// AUTH & VERIFICATION
// ============================================

model Otp {
  id          String      @id @default(cuid())
  phone       String
  code        String
  purpose     OtpPurpose  @default(LOGIN)
  attempts    Int         @default(0)
  maxAttempts Int         @default(3)
  isUsed      Boolean     @default(false)
  expiresAt   DateTime
  createdAt   DateTime    @default(now())

  @@index([phone, code, isUsed])
  @@index([expiresAt])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model IdentityCheck {
  id              String              @id @default(cuid())
  userId          String
  type            String              // NIN, BVN, DRIVER_LICENSE, FACE_COMPARISON, BANK_ACCOUNT
  idNumber        String?
  status          VerificationStatus  @default(PENDING)
  rawResponse     Json?
  errorMessage    String?
  verifiedAt      DateTime?
  createdAt       DateTime            @default(now())

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([status])
}

// ============================================
// RIDES & BOOKINGS
// ============================================

model Ride {
  id              String        @id @default(cuid())
  driverId        String
  originLat       Float
  originLng       Float
  originAddress   String
  originArea      String?       // e.g. "Ikorodu"
  destLat         Float
  destLng         Float
  destAddress     String
  destArea        String?       // e.g. "Victoria Island"
  departureTime   DateTime
  availableSeats  Int
  totalSeats      Int
  pricePerSeat    Int           // in kobo (₦800 = 80000)
  vehicleType     VehicleType
  status          RideStatus    @default(SCHEDULED)
  isRecurring     Boolean       @default(false)
  recurringDays   String?       // "MON,TUE,WED,THU,FRI"
  parentRideId    String?       // if generated from a recurring template
  notes           String?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  driver          User          @relation("DriverRides", fields: [driverId], references: [id])
  bookings        Booking[]
  ratings         Rating[]
  parentRide      Ride?         @relation("RecurringRides", fields: [parentRideId], references: [id])
  childRides      Ride[]        @relation("RecurringRides")

  @@index([status, departureTime])
  @@index([driverId, status])
  @@index([originLat, originLng])
  @@index([destLat, destLng])
  @@index([departureTime])
  @@index([originArea, destArea])
}

model Booking {
  id            String          @id @default(cuid())
  rideId        String
  riderId       String
  seats         Int             @default(1)
  totalPrice    Int             // in kobo
  status        BookingStatus   @default(PENDING)
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ride          Ride            @relation(fields: [rideId], references: [id])
  rider         User            @relation("RiderBookings", fields: [riderId], references: [id])
  payment       Payment?

  @@unique([rideId, riderId])
  @@index([riderId, status])
  @@index([rideId, status])
  @@index([status])
}

// ============================================
// PAYMENTS & WITHDRAWALS
// ============================================

model Payment {
  id                  String          @id @default(cuid())
  bookingId           String          @unique
  userId              String
  amount              Int             // in kobo
  currency            String          @default("NGN")
  provider            String          @default("INTERSWITCH") // INTERSWITCH | PAYCODE
  transactionRef      String          @unique
  paymentRef          String?         // from Interswitch response
  responseCode        String?
  responseDescription String?
  status              PaymentStatus   @default(PENDING)
  metadata            Json?
  verifiedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  booking             Booking         @relation(fields: [bookingId], references: [id])
  user                User            @relation(fields: [userId], references: [id])

  @@index([transactionRef])
  @@index([userId, status])
  @@index([status])
}

model Withdrawal {
  id                  String    @id @default(cuid())
  driverProfileId     String
  amount              Int       // in kobo
  bankAccountNumber   String
  bankCode            String
  bankName            String
  accountName         String
  transactionRef      String    @unique
  responseCode        String?
  status              PaymentStatus @default(PENDING)
  processedAt         DateTime?
  createdAt           DateTime  @default(now())

  driverProfile       DriverProfile @relation(fields: [driverProfileId], references: [id])

  @@index([driverProfileId])
  @@index([status])
}

// ============================================
// RATINGS & TRUST
// ============================================

model Rating {
  id          String    @id @default(cuid())
  rideId      String
  fromUserId  String
  toUserId    String
  score       Int       // 1-5
  comment     String?
  createdAt   DateTime  @default(now())

  ride        Ride      @relation(fields: [rideId], references: [id])
  fromUser    User      @relation("RatingsGiven", fields: [fromUserId], references: [id])
  toUser      User      @relation("RatingsReceived", fields: [toUserId], references: [id])

  @@unique([rideId, fromUserId])
  @@index([toUserId])
  @@index([rideId])
}
